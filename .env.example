# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (get from @userinfobot)
CHAT_ID=your_chat_id_here

# Wallet P2P API Key (get from Wallet -> P2P Market -> Profile -> API Keys)
WALLET_API_KEY=your_wallet_api_key_here

# === Monitoring Settings ===

# Check interval in seconds (default: 30)
CHECK_INTERVAL=30

# Crypto currency to monitor (USDT, BTC, TON, NOT)
CRYPTO_CURRENCY=USDT

# Fiat currency (KZT, RUB, USD, EUR, UAH, etc.)
FIAT_CURRENCY=KZT

# Trade side: BUY, SELL, or BOTH
# BUY  = you want to BUY crypto (looking at sellers' ads)
# SELL = you want to SELL crypto (looking at buyers' ads)
# BOTH = monitoring both boundaries
SIDE=BOTH

# Price threshold alert — bot will notify when price hits these limits
# SELL_THRESHOLD triggers when drop <= value (you buy crypto cheaper)
# BUY_THRESHOLD triggers when rise >= value (you sell crypto more expensive, trash orders)
SELL_THRESHOLD=
BUY_THRESHOLD=

# Port for Express keep-alive server (Render requirement)
PORT=3000
