# === Required ===
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_telegram_chat_id
WALLET_API_KEY=your_wallet_p2p_api_key

# === Monitoring Settings ===
CHECK_INTERVAL=30          # Check interval in seconds
CRYPTO_CURRENCY=USDT       # Crypto currency to monitor

# === Thresholds per pair ===
# USDT/KZT thresholds
SELL_THRESHOLD_KZT=        # Alert when buy price <= this (e.g. 445)

# USDT/RUB thresholds
SELL_THRESHOLD_RUB=        # Alert when buy price <= this (e.g. 85)

# === Server ===
PORT=3000                  # Express keep-alive port
